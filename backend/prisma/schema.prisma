generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?  @unique
  password  String
  nickname  String
  avatar    String?
  role      Role     @default(USER)
  realName  String?
  idCard    String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Relations
  products  Product[]
  orders    Order[]
  favorites Favorite[]
  reviews   Review[]
  messages  Message[]
}

model Product {
  id              String          @id @default(cuid())
  title           String
  type            ProductType
  price           Decimal
  originalPrice   Decimal?
  condition       ProductCondition
  brand           String?
  maker           String?
  origin          String
  size            String?
  stage           ProductStage
  year            String?
  description     String
  soundDescription String?
  flaws           String?
  repairHistory   String?
  hasCertificate  Boolean         @default(false)
  supportOfflineTrial Boolean     @default(false)
  supportPlatformTrial Boolean   @default(false)
  platformCertified Boolean       @default(false)
  negotiable      Boolean         @default(false)
  status          ProductStatus   @default(AVAILABLE)
  viewCount       Int             @default(0)
  favoriteCount   Int             @default(0)
  sellerId        String
  seller          User            @relation("SellerProducts", fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  // Relations
  images          ProductImage[]
  orderItems      OrderItem[]
  favorites       Favorite[]
  reviews         Review[]
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(PENDING)
  totalAmount Decimal
  paymentMethod String?
  paymentTime DateTime?
  shippingMethod String?
  shippingAddress String?
  remark      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  // Relations
  items       OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  price     Decimal
  createdAt DateTime @default(now())
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  
  @@unique([userId, productId])
}

model Review {
  id        String  @id @default(cuid())
  rating    Int     @db.SmallInt
  content   String
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Message {
  id        String    @id @default(cuid())
  content   String
  type      MessageType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model Article {
  id        String    @id @default(cuid())
  title     String
  summary   String
  content   String
  coverImage String?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  ArticleCategory
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Question {
  id        String       @id @default(cuid())
  title     String
  content   String
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  QACategory
  status    QAStatus     @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  // Relations
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  content    String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isExpert   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

enum Role {
  USER
  SELLER
  EXPERT
  ADMIN
}

enum ProductType {
  VIOLIN
  BOW
  ACCESSORY
}

enum ProductCondition {
  NEW
  MINT
  GOOD
  USED
  FAIR
}

enum ProductStage {
  BEGINNER
  EXAM
  PROFESSIONAL
  COLLECTION
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
  OFFLINE
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum MessageType {
  SYSTEM
  ORDER
  CONSULT
}

enum ArticleCategory {
  GUIDE
  REVIEW
  NEWS
  MAINTENANCE
}

enum QACategory {
  CHOOSE
  PRICE
  MAINTENANCE
  REPAIR
  OTHER
}

enum QAStatus {
  PENDING
  ANSWERED
  CLOSED
}